# ---- Supabase (managed Postgres) ----
SUPABASE_DB_URL=jdbc:postgresql://db.<project>.supabase.co:5432/postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=change-me

# ---- Neo4j ----
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me

# ---- OpenAI — used only for STT (Whisper) ----
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-change-me

# ---- GLM via ILMU — used for all LLM agent calls ----
GLM_BASE_URL=https://api.ilmu.ai/v1
GLM_API_KEY=change-me
GLM_MODEL=ilmu-glm-5.1

# ---- JWT / Spring Security ----
JWT_SECRET=change-me-dev-only-at-least-32-chars
JWT_EXPIRY_MINUTES=60

# ---- Inter-service auth (Spring Boot → Python agent) ----
AGENT_SERVICE_TOKEN=change-me
AGENT_SERVICE_URL=http://agent:8000

# ---- Speech-to-text ----
STT_PROVIDER=whisper
STT_API_KEY=change-me

# ---- Observability ----
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
