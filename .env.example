# ---- Supabase (managed Postgres) ----
SUPABASE_DB_URL=jdbc:postgresql://db.<project>.supabase.co:5432/postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=change-me

# ---- Neo4j ----
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me

# ---- OpenAI — used only for STT (Whisper) ----
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-change-me

# ---- GLM via ILMU — used for all LLM agent calls ----
GLM_BASE_URL=https://api.ilmu.ai/v1
GLM_API_KEY=change-me
GLM_MODEL=ilmu-glm-5.1

# ---- JWT / Spring Security ----
JWT_SECRET=change-me-dev-only-at-least-32-chars
JWT_EXPIRY_MINUTES=60

# ---- Inter-service auth (Spring Boot → Python agent) ----
AGENT_SERVICE_TOKEN=change-me
AGENT_SERVICE_URL=http://agent:8000

# ---- Speech-to-text ----
STT_PROVIDER=whisper
STT_API_KEY=change-me

# ---- Observability ----
OTEL_EXPORTER_OTLP_ENDPOINT=

# Sentry — empty DSN disables the SDK (zero overhead, no errors).
# Free tier: 5k events/month. See SAD §4.2.1.
# Get DSNs from https://sentry.io/settings/projects/<project>/keys/
# One Sentry project per service (recommended) or share one DSN across all three.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=cliniflow@0.0.1

# Frontend (Next.js) — public DSN is exposed to the browser (this is normal for Sentry).
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_RELEASE=cliniflow-frontend@0.1.0

# Optional — only set these if you want source map upload during `npm run build`.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ---- WhatsApp ----
# WHATSAPP_PROVIDER selects the outbound transport:
#   stub        — logs messages locally, no external call (default for tests/CI)
#   twilio      — Twilio Sandbox / Business API. Recipients must opt in first
#                 (send the sandbox join-code), then free-text replies for 24h.
#   meta-cloud  — Meta WhatsApp Cloud API (Graph API). In dev mode uses Meta's
#                 test number + recipient allowlist; production-grade default.
WHATSAPP_PROVIDER=stub

# ---- Twilio (used when WHATSAPP_PROVIDER=twilio) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_WHATSAPP=whatsapp:+14155238886

# ---- Meta WhatsApp Cloud API (used when WHATSAPP_PROVIDER=meta-cloud) ----
# Get these from developers.facebook.com → your app → WhatsApp → API Setup:
#   META_PHONE_NUMBER_ID  — long numeric id of the sender phone number
#   META_ACCESS_TOKEN     — temp 24h token, OR a permanent system-user token
#   META_API_VERSION      — Graph API version (v21.0 is current)
# Template config: in dev mode use Meta's pre-approved hello_world template
# (no variables). For production swap in your own approved template name +
# locale code, e.g. "cliniflow_appointment_confirmation_v1" / "en_US".
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
META_API_VERSION=v21.0
META_DEFAULT_TEMPLATE_NAME=hello_world
META_DEFAULT_TEMPLATE_LANGUAGE=en_US

# Per-event Meta template names. Defaults assume you've submitted templates
# with these names in WhatsApp Manager. Until each one is APPROVED by Meta,
# Meta returns error 132001 ("template does not exist") which is logged as
# Terminal — set the variable below to "hello_world" to fall back to Meta's
# pre-approved no-variable template for any event whose custom template
# isn't yet approved.
META_TEMPLATE_APPOINTMENT_CONFIRMATION=cliniflow_appointment_confirmation_v1
META_TEMPLATE_APPOINTMENT_CANCELLED=cliniflow_appointment_cancelled_v1
META_TEMPLATE_SOAP_MEDS_SUMMARY=cliniflow_soap_meds_summary_v1
META_TEMPLATE_SOAP_FOLLOWUP_REMINDER=cliniflow_soap_followup_reminder_v1
